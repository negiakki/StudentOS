# StudentOS frontend environment. Copy to `.env.local` and fill in real values.
# Only NEXT_PUBLIC_* vars are exposed to the browser.

# Backend API base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Public site origin (used to build auth redirect URLs). Optional in local dev —
# the request origin is used automatically. Set this in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (client) — Phase 2
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
