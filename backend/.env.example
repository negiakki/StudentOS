# StudentOS backend environment. Copy to `.env` and fill in real values.
# `.env` is git-ignored; never commit secrets.

# --- App ---
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000

# --- Database (Supabase Postgres) — Phase 3 ---
DATABASE_URL=postgresql+psycopg://user:password@host:5432/postgres

# --- Supabase Auth — Phase 2 ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=

# --- Supabase Storage (timetable uploads) — Phase 4 ---
# Service-role key is server-side only; never expose it to the frontend.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=timetables

# --- AI provider layer — Phase 4.5 ---
# The app talks only to the vision/chat routers; provider choice is config-only.
# Changing providers should require editing only this section.
VISION_PROVIDER=gemini
CHAT_PROVIDER=openrouter
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# Override only for proxies or OpenRouter-compatible gateways.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
WATSONX_API_KEY=

# V1 ships storage-only timetable upload (no AI). Set true in V2 to re-enable
# automatic parsing (parser code is preserved behind this flag).
ENABLE_TIMETABLE_PARSING=false
